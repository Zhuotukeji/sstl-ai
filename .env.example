# API
API_HOST=0.0.0.0
API_PORT=8787
WEB_ORIGIN=http://localhost:5173

# AI platform persistence. Leave empty to use in-memory seed data for local preview.
AI_PLATFORM_DATABASE_URL=postgres://sstl_ai:sstl_ai@localhost:5432/sstl_ai

# SSTL readonly production database. Use a readonly account only.
SSTL_DB_HOST=
SSTL_DB_PORT=3306
SSTL_DB_USER=
SSTL_DB_PASSWORD=
SSTL_DB_NAME=
SSTL_DB_SSL=false

# OpenAI-compatible model endpoint. Leave OPENAI_API_KEY empty to use deterministic fallback responses.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Security
DATA_ENCRYPTION_KEY=replace-with-32-byte-random-string
AUDIT_REDACTION_SALT=replace-with-random-salt

# Web
VITE_API_BASE_URL=http://localhost:8787
